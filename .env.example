# LLM provider: "ollama" or "openai_compatible" (LM Studio, llama.cpp server, etc.)
LLM_PROVIDER=ollama

# Ollama (local LLM, default provider)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_DEFAULT_MODEL=llama3
OLLAMA_TIMEOUT_SECONDS=120

# OpenAI-compatible local server (used when LLM_PROVIDER=openai_compatible).
# LM Studio defaults: http://localhost:1234/v1, no real API key required.
# Leave OPENAI_COMPATIBLE_MODEL empty to auto-pick whatever model is loaded.
OPENAI_COMPATIBLE_BASE_URL=http://localhost:1234/v1
OPENAI_COMPATIBLE_MODEL=
OPENAI_COMPATIBLE_API_KEY=lm-studio
OPENAI_COMPATIBLE_TIMEOUT_SECONDS=120

# Embeddings (Phase 2 RAG):
#   default            = ChromaDB's bundled all-MiniLM-L6-v2 (English only)
#   openai_compatible  = /v1/embeddings (LM Studio nomic-embed-text is multilingual)
#   ollama             = Ollama /api/embed (e.g. ollama pull nomic-embed-text)
# Empty *_BASE_URL / *_API_KEY reuse the matching LLM provider config.
EMBEDDING_PROVIDER=default
EMBEDDING_BASE_URL=
EMBEDDING_MODEL=text-embedding-nomic-embed-text-v1.5
EMBEDDING_API_KEY=
EMBEDDING_TIMEOUT_SECONDS=60

# Database
DATABASE_URL=sqlite:///./vedanta.db

# ChromaDB
CHROMA_PERSIST_DIR=./data/chroma

# Instagram (Phase 3)
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
INSTAGRAM_PAGE_TOKEN=
INSTAGRAM_VERIFY_TOKEN=

# Security
# Generate values with: openssl rand -hex 32
SECRET_KEY=
ENCRYPTION_KEY=

# JWT lifetime (minutes). After this the user has to log in again.
JWT_EXPIRE_MINUTES=1440

# Rate limits (slowapi syntax: "<count>/<period>", e.g. "30/minute").
# Anonymous traffic is keyed by client IP; authenticated traffic by
# the user id. Auth endpoints get their own (tight) bucket so brute
# force attempts are capped.
RATE_LIMIT_CHAT_ANONYMOUS=30/minute
RATE_LIMIT_CHAT_AUTHENTICATED=120/minute
RATE_LIMIT_AUTH=10/minute

# Sanskrit Heritage Platform (Phase 3+, optional). When enabled, the
# sanskrit_grammar agent calls a deterministic morphological parser
# BEFORE the LLM and prepends the analysis as structural grounding.
# Default disabled — agent falls back to LLM-only without errors.
# The default URL targets the public Inria SHP CGI; for production
# point at a self-hosted Docker instance to avoid external deps.
SANSKRIT_HERITAGE_ENABLED=false
SANSKRIT_HERITAGE_BASE_URL=https://sanskrit.inria.fr/cgi-bin/SKT/sktreader.cgi
SANSKRIT_HERITAGE_INPUT_SCHEME=RN
SANSKRIT_HERITAGE_TIMEOUT_SECONDS=8

# App
ADMIN_EMAIL=
LOCAL_TIMEZONE=Asia/Kolkata
APP_HOST=127.0.0.1
APP_PORT=8000

# CORS (comma-separated origins for the frontend)
CORS_ORIGINS=http://localhost:3000

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
