# Docker Compose env. Copy this to .env and edit:
#   cp .env.docker.example .env
#
# This file ONLY contains the variables compose substitutes into
# docker-compose.yml. Variables consumed by the application itself
# (LLM_PROVIDER, OLLAMA_BASE_URL, etc.) are forwarded by the
# `environment:` block on each service in compose, so changing them
# here is enough — no need to also edit a backend-side .env.

# --- secrets (REQUIRED) -----------------------------------------------
# Generate with: openssl rand -hex 32
SECRET_KEY=
ENCRYPTION_KEY=

# --- Postgres ---------------------------------------------------------
POSTGRES_USER=vedanta
POSTGRES_PASSWORD=changeme
POSTGRES_DB=vedanta
POSTGRES_PORT=5432

# --- Chroma -----------------------------------------------------------
# Host port the Chroma server listens on. The internal service-to-service
# port stays at 8000 inside the Docker network.
CHROMA_PORT=8001

# --- Ports ------------------------------------------------------------
BACKEND_PORT=8000
FRONTEND_PORT=3000

# --- LLM (the LLM runs on the HOST, not in Docker) -------------------
# macOS / Windows users: leave the host.docker.internal aliases.
# Linux users without that alias: replace with 172.17.0.1 or your
# bridge gateway IP, or `extra_hosts: host-gateway` in compose (already
# wired) is enough on recent Docker Engine.
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_DEFAULT_MODEL=llama3

OPENAI_COMPATIBLE_BASE_URL=http://host.docker.internal:1234/v1
OPENAI_COMPATIBLE_MODEL=
OPENAI_COMPATIBLE_API_KEY=lm-studio

# --- Embeddings -------------------------------------------------------
# "default" works without a server; for multilingual support point
# this at LM Studio's nomic-embed-text-v1.5.
EMBEDDING_PROVIDER=default
EMBEDDING_BASE_URL=
EMBEDDING_MODEL=text-embedding-nomic-embed-text-v1.5

# --- JWT / rate limits ------------------------------------------------
JWT_EXPIRE_MINUTES=1440
RATE_LIMIT_CHAT_ANONYMOUS=30/minute
RATE_LIMIT_CHAT_AUTHENTICATED=120/minute
RATE_LIMIT_AUTH=10/minute

# --- Sanskrit Heritage Platform --------------------------------------
SANSKRIT_HERITAGE_ENABLED=false
SANSKRIT_HERITAGE_BASE_URL=https://sanskrit.inria.fr/cgi-bin/SKT/sktreader.cgi

# --- CORS / frontend --------------------------------------------------
# What the frontend bakes in for fetch() at build time. When proxying
# through a reverse proxy, set this to the public URL.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
CORS_ORIGINS=http://localhost:3000,http://frontend:3000
